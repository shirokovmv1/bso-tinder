# ─────────────────────────────────────────────────────────────────────────────
# BSO Tinder — PROD окружение (порт 80)
# Скопируй: cp .env.prod.example .env.prod  и заполни реальными значениями.
# .env.prod никогда не попадает в git.
# ─────────────────────────────────────────────────────────────────────────────

PORT=3001
NODE_ENV=production
APP_ENV=prod
ALLOW_DEV_LOGIN=false

# Сгенерировать: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=ЗАМЕНИТЕ_НА_СЛУЧАЙНУЮ_СТРОКУ_МИН_32_СИМВОЛА
JWT_EXPIRES_IN=24h

FRONTEND_ORIGIN=http://158.255.5.199

ALLOWED_DOMAIN=bso-cc.ru
ALLOWED_EXTRA_EMAILS=
ADMIN_EMAILS=admin@bso-cc.ru

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-login@gmail.com
SMTP_PASS=ваш_app_password
SMTP_FROM="БСО Корпоратив" <your-smtp-login@gmail.com>
