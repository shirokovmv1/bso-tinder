# ─────────────────────────────────────────────────────────────────────────────
# BSO Tinder — TEST окружение (порт 8080)
# Скопируй: cp .env.test.example .env.test  и заполни реальными значениями.
# .env.test никогда не попадает в git.
# ─────────────────────────────────────────────────────────────────────────────

PORT=3001
NODE_ENV=production
APP_ENV=test
ALLOW_DEV_LOGIN=true

# Можно использовать другой JWT_SECRET, чтобы test-токены не работали на prod
JWT_SECRET=ЗАМЕНИТЕ_НА_ДРУГУЮ_СЛУЧАЙНУЮ_СТРОКУ
JWT_EXPIRES_IN=24h

FRONTEND_ORIGIN=http://158.255.5.199:8080

ALLOWED_DOMAIN=bso-cc.ru
ALLOWED_EXTRA_EMAILS=tester@gmail.com
ADMIN_EMAILS=admin@bso-cc.ru

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-login@gmail.com
SMTP_PASS=ваш_app_password
SMTP_FROM="BSO Test" <your-smtp-login@gmail.com>
