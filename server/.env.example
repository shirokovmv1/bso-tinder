# Сервер
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=24h

# CORS — адрес фронтенда
FRONTEND_ORIGIN=http://localhost:5173

# Вайтлист: разрешённый домен корпоративной почты
ALLOWED_DOMAIN=bso-cc.ru
# Дополнительные email через запятую (для тестирования или внешних сотрудников)
ALLOWED_EXTRA_EMAILS=

# Администраторы — email через запятую, получают is_admin=1 при первом входе
ADMIN_EMAILS=

# SMTP (Gmail: используй App Password, не обычный пароль!)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM="БСО Корпоратив <your@gmail.com>"
